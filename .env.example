# Copy this file to .env.local and fill in real values
# NEVER commit .env.local — it's in .gitignore

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OpenClaw service token (for Telegram agent → API communication)
SERVICE_TOKEN="generate-a-random-token-here"

# LLM Provider for agent chat panel
# Options: "gemini" (default), "ollama" (local)
LLM_PROVIDER="gemini"

# Gemini (default provider — generous free tier)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"

# Ollama (local — free, run `ollama pull qwen2.5:7b` first)
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="qwen2.5:7b"
